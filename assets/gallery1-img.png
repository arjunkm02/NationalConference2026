    <title>BIET-NCAIET 25-Gallery</title>
  <!-- Bootstrap CSS -->
  <link href="./gallery1-img_files/bootstrap.min.css" rel="stylesheet">

  <!-- Swiper CSS -->
  <link rel="stylesheet" href="./gallery1-img_files/swiper-bundle.min.css">
